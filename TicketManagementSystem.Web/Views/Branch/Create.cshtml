@model TicketManagementSystem.Domain.Entities.Branch

@{
    ViewData["Title"] = "Create Branch";
}

<div class="tms-card" style="max-width:700px; margin:auto;">

    <div class="mb-4">
        <h3 class="fw-bold mb-1">
            <i class="fa-solid fa-building-circle-plus text-primary me-2"></i>
            Create Branch
        </h3>

        <div class="text-muted small">
            Add a new branch location
        </div>
    </div>

    <form asp-action="Create" method="post">

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label fw-semibold">
                Branch Code
            </label>

            <input asp-for="BranchCode"
                   class="form-control"
                   placeholder="e.g. KTM001" />

            <span asp-validation-for="BranchCode" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">
                Location
            </label>

            <input asp-for="Location"
                   class="form-control"
                   placeholder="e.g. Kathmandu" />

            <span asp-validation-for="Location" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-end gap-2">

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Back
            </a>

            <button type="submit"
                    class="btn btn-success">
                <i class="fa-solid fa-check"></i>
                Save Branch
            </button>

        </div>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}