@model TicketManagementSystem.Common.Models.Auth.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

@section Styles {
    <style>
        body {
            background: radial-gradient(circle at top left, #f0ecff 0%, #f6f8ff 38%, #eef4ff 100%);
        }
        .login-shell {
            min-height: calc(100vh - 120px);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            width: 100%;
            max-width: 460px;
            border: 0;
            border-radius: 1.2rem;
            box-shadow: 0 18px 44px rgba(27, 39, 94, .14);
            overflow: hidden;
        }
        .login-brand-badge {
            width: 56px;
            height: 56px;
            border-radius: 1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(90deg, #6C47FF 0%, #00D2D3 100%);
            color: #fff;
            font-size: 1.35rem;
            box-shadow: 0 10px 28px rgba(108, 71, 255, .28);
        }
        .login-icon {
            min-width: 46px;
            justify-content: center;
        }
    </style>
}

<div class="login-shell">
    <div class="login-card bg-white p-4 p-md-5">
        <div class="text-center mb-4">
            <div class="login-brand-badge mb-3">
                <i class="fa-solid fa-ticket"></i>
            </div>
            <h4 class="fw-bold mb-1">Ticket Management System</h4>
            <p class="text-muted small mb-0">Sign in to continue to your dashboard</p>
        </div>

        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger py-2">
                @Html.ValidationSummary()
            </div>
        }

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold"></label>
                <div class="input-group">
                    <span class="input-group-text bg-white login-icon">
                        <i class="fa-regular fa-envelope text-muted"></i>
                    </span>
                    <input asp-for="Email" class="form-control" placeholder="Enter your email or username" />
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold"></label>
                <div class="input-group">
                    <span class="input-group-text bg-white login-icon">
                        <i class="fa-solid fa-lock text-muted"></i>
                    </span>
                    <input asp-for="Password" class="form-control" type="password" placeholder="Enter your password" />
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary py-2 fw-semibold">
                    <i class="fa-solid fa-right-to-bracket me-2"></i>Login
                </button>
            </div>
        </form>

        <div class="text-center small text-muted mt-4">
            &copy; @DateTime.Now.Year Ticket Management System
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
