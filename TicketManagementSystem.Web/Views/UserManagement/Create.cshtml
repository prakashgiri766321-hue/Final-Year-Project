@model TicketManagementSystem.Application.DTOs.CreateUserDto

@{
    ViewData["Title"] = "Create User";
    ViewData["Subtitle"] = "Add a new user account";
}

@section PageActions {
    <a asp-action="Index" class="btn btn-outline-secondary tms-btn-spacious" style="border-radius:1.4rem;">
        <i class="fa-solid fa-arrow-left"></i>
        Back
    </a>
}

<div class="tms-card" style="max-width:900px;margin:0 auto;">
    <div class="mb-4">
        <div class="h4 fw-bold mb-1">
            <i class="fa-solid fa-user-plus text-primary me-2"></i>
            Create User
        </div>

        <div class="text-muted small">
            Create an account and assign a role.
        </div>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label asp-for="FullName" class="form-label fw-semibold"></label>
                <div class="input-group">
                    <span class="input-group-text bg-white"
                          style="min-width:46px;justify-content:center;">
                        <i class="fa-solid fa-id-card text-muted"></i>
                    </span>

                    <input asp-for="FullName"
                           class="form-control"
                           placeholder="Enter full name" />
                </div>

                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="col-12 col-md-6">
                <label asp-for="UserName" class="form-label fw-semibold"></label>

                <div class="input-group">
                    <span class="input-group-text bg-white"
                          style="min-width:46px;justify-content:center;">
                        <i class="fa-regular fa-user text-muted"></i>
                    </span>

                    <input asp-for="UserName"
                           class="form-control"
                           placeholder="Enter username" />
                </div>

                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>

        
            <div class="col-12 col-md-6">
                <label asp-for="Email" class="form-label fw-semibold"></label>

                <div class="input-group">
                    <span class="input-group-text bg-white"
                          style="min-width:46px;justify-content:center;">
                        <i class="fa-regular fa-envelope text-muted"></i>
                    </span>

                    <input asp-for="Email"
                           class="form-control"
                           placeholder="Enter email" />
                </div>

                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="col-12 col-md-6">
                <label asp-for="Password" class="form-label fw-semibold"></label>

                <div class="input-group">
                    <span class="input-group-text bg-white"
                          style="min-width:46px;justify-content:center;">
                        <i class="fa-solid fa-lock text-muted"></i>
                    </span>

                    <input asp-for="Password"
                           class="form-control"
                           type="password"
                           placeholder="Enter password" />
                </div>

                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="col-12 col-md-6">
                <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>

                <div class="input-group">
                    <span class="input-group-text bg-white"
                          style="min-width:46px;justify-content:center;">
                        <i class="fa-solid fa-lock text-muted"></i>
                    </span>

                    <input asp-for="ConfirmPassword"
                           class="form-control"
                           type="password"
                           placeholder="Re-enter password" />
                </div>

                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="col-12 col-md-6">
                <label asp-for="Role" class="form-label fw-semibold"></label>
                <div class="input-group">
                    <span class="input-group-text bg-white"
                          style="min-width:46px;justify-content:center;">
                        <i class="fa-solid fa-user-shield text-muted"></i>
                    </span>

                    <select asp-for="Role"
                            class="form-select"
                            asp-items="ViewBag.Roles">
                        <option value="">-- Select Role --</option>
                    </select>
                </div>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>
        </div>

        <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end mt-4">

            <a asp-action="Index"
               class="btn btn-outline-secondary tms-btn-icon">
                <i class="fa-solid fa-arrow-left"></i>
                Cancel
            </a>

            <button type="submit"
                    class="btn btn-success tms-btn-icon px-4">
                <i class="fa-solid fa-check"></i>
                Create User
            </button>

        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}