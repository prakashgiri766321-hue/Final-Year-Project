@model List<TicketManagementSystem.Infrastructure.Identity.ApplicationUser>

@{
    ViewData["Title"] = "User Management";
    ViewData["Subtitle"] = "Manage access and roles";

    var roleMap = ViewBag.UserRoles as Dictionary<string, string> ?? new Dictionary<string, string>();
    var sn = 1;
}
@section PageActions {
    <a asp-action="Create" class="btn btn-primary tms-btn-spacious" style="border-radius:1.4rem;">
        <i class="fa-solid fa-user-plus"></i>
        Add New User
    </a>
}

<div class="tms-card">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mb-3">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="table-responsive">
        <table class="table align-middle tms-table mb-0">
            <thead>
                <tr>
                    <th style="width:80px;">SN</th>
                    <th>NAME</th>
                    <th>EMAIL</th>
                    <th style="width:140px;">ROLE</th>
                    <th style="width:140px;">STATUS</th>
                    <th style="width:220px;">ACTION</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var user in Model)
                    {
                        var role = roleMap.TryGetValue(user.Id, out var value) ? value : "-";
                        var roleBadgeClass = role == "Admin" ? "badge-open" : "badge-priority-medium";

                        <tr>
                            <td class="text-muted fw-bold">@sn</td>
                            <td class="fw-semibold">@user.UserName</td>
                            <td class="text-muted">@user.Email</td>
                            <td>
                                <span class="badge badge-soft @roleBadgeClass">
                                    <i class="fa-solid fa-user-shield"></i> @role
                                </span>
                            </td>
                            <td>
                                <span class="badge badge-soft badge-closed">
                                    <i class="fa-solid fa-circle-check"></i> Active
                                </span>
                            </td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">

                                    <a asp-action="Details"
                                       asp-route-id="@user.Id"
                                       class="btn btn-sm btn-primary tms-btn-icon">
                                        <i class="fa-regular fa-eye"></i>
                                        Details
                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@user.Id"
                                       class="btn btn-sm btn-warning tms-btn-icon">
                                        <i class="fa-solid fa-pen"></i>
                                        Edit
                                    </a>
                                </div>
                            </td>
                        </tr>

                        sn++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6">
                            <div class="tms-empty-state">
                                <i class="fa-regular fa-folder-open"></i>
                                <div class="fw-semibold mt-2">No users found</div>
                                <div class="small mt-1">Create a new user to get started.</div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>