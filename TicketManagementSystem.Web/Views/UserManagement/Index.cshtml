@{
    ViewData["Title"] = "User Management";
    ViewData["Subtitle"] = "Manage access and roles";
}
@section PageActions {
    <button class="btn btn-primary tms-btn-spacious" style="border-radius:1.4rem;" disabled>
        <i class="fa-solid fa-user-plus"></i>
        Add New User
    </button>
}

<div class="tms-card">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-2 mb-3">
        <div class="input-group" style="max-width:360px;">
            <span class="input-group-text bg-white">
                <i class="fa-solid fa-magnifying-glass text-muted"></i>
            </span>
            <input type="text" class="form-control" placeholder="Search user (UI only)" disabled />
        </div>
    </div>

    <div class="table-responsive">
        <table class="table align-middle tms-table mb-0">
            <thead>
                <tr>
                    <th style="width:80px;">SN</th>
                    <th>NAME</th>
                    <th>EMAIL</th>
                    <th style="width:140px;">ROLE</th>
                    <th style="width:140px;">STATUS</th>
                    <th style="width:220px;">ACTION</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="text-muted fw-bold">1</td>
                    <td class="fw-semibold">Admin User</td>
                    <td class="text-muted">admin@tms.com</td>
                    <td><span class="badge badge-soft badge-open"><i class="fa-solid fa-shield-halved"></i> Admin</span></td>
                    <td><span class="badge badge-soft badge-closed"><i class="fa-solid fa-circle-check"></i> Active</span></td>
                    <td>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-sm btn-warning tms-btn-icon" disabled><i class="fa-regular fa-pen-to-square"></i> Edit</button>
                            <button class="btn btn-sm btn-danger tms-btn-icon" disabled><i class="fa-regular fa-trash-can"></i> Delete</button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td class="text-muted fw-bold">2</td>
                    <td class="fw-semibold">Prakash Sharma</td>
                    <td class="text-muted">prakash@gmail.com</td>
                    <td><span class="badge badge-soft badge-priority-medium"><i class="fa-regular fa-user"></i> User</span></td>
                    <td><span class="badge badge-soft badge-closed"><i class="fa-solid fa-circle-check"></i> Active</span></td>
                    <td>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-sm btn-warning tms-btn-icon" disabled><i class="fa-regular fa-pen-to-square"></i> Edit</button>
                            <button class="btn btn-sm btn-danger tms-btn-icon" disabled><i class="fa-regular fa-trash-can"></i> Delete</button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td class="text-muted fw-bold">3</td>
                    <td class="fw-semibold">Bijay Shrestha</td>
                    <td class="text-muted">bijay@gmail.com</td>
                    <td><span class="badge badge-soft badge-priority-medium"><i class="fa-regular fa-user"></i> User</span></td>
                    <td><span class="badge badge-soft badge-open"><i class="fa-solid fa-circle-xmark"></i> Inactive</span></td>
                    <td>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-sm btn-warning tms-btn-icon" disabled><i class="fa-regular fa-pen-to-square"></i> Edit</button>
                            <button class="btn btn-sm btn-danger tms-btn-icon" disabled><i class="fa-regular fa-trash-can"></i> Delete</button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td class="text-muted fw-bold">4</td>
                    <td class="fw-semibold">Anita Sharma</td>
                    <td class="text-muted">anita@gmail.com</td>
                    <td><span class="badge badge-soft badge-priority-medium"><i class="fa-regular fa-user"></i> User</span></td>
                    <td><span class="badge badge-soft badge-closed"><i class="fa-solid fa-circle-check"></i> Active</span></td>
                    <td>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-sm btn-warning tms-btn-icon" disabled><i class="fa-regular fa-pen-to-square"></i> Edit</button>
                            <button class="btn btn-sm btn-danger tms-btn-icon" disabled><i class="fa-regular fa-trash-can"></i> Delete</button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>