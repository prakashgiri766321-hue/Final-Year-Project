@{
    ViewData["Title"] = "User Management";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

<style>
    body {
        background: #f6f7fb;
        font-family: "Segoe UI",sans-serif;
    }

    .sidebar {
        width: 250px;
        height: 100vh;
        background: #fff;
        position: fixed;
        left: 0;
        top: 0;
        border-right: 1px solid #eee;
    }

        .sidebar .logo {
            padding: 20px;
            font-weight: bold;
            color: #0d6efd;
        }

        .sidebar a {
            display: block;
            padding: 14px 20px;
            color: #555;
            text-decoration: none;
        }

            .sidebar a:hover,
            .sidebar a.active {
                background: #f0f4ff;
                color: #0d6efd;
                font-weight: 500;
            }

    .main {
        margin-left: 260px;
        padding: 30px;
    }

    .card-box {
        background: white;
        border-radius: 10px;
        padding: 20px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.05);
    }

    .btn-add {
        background: #4a8df6;
        color: white;
        border-radius: 8px;
        padding: 8px 18px;
    }

    .btn-action {
        padding: 5px 12px;
        border-radius: 8px;
        border: none;
        color: white;
    }

    .btn-edit {
        background: #4a8df6;
    }

    .btn-delete {
        background: #ff4d5a;
    }

    .role-badge {
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 12px;
    }

    .role-admin {
        background: #ffe5e8;
        color: #ff4d5a;
    }

    .role-user {
        background: #e6f0ff;
        color: #4a8df6;
    }
</style>

<!-- Sidebar -->
<div class="sidebar d-flex flex-column justify-content-between">

    <div>

        <div class="logo">
            🎫 TMS<br>
            <small class="text-muted">Ticket Management System</small>
        </div>

        <a asp-controller="Home" asp-action="Index">
            <i class="fa fa-chart-pie me-2"></i> Dashboard
        </a>

        <a asp-controller="Ticket" asp-action="Index">
            <i class="fa fa-ticket me-2"></i> Tickets
        </a>

        <a asp-controller="FormAndPolicies" asp-action="Index">
            <i class="fa fa-file-alt me-2"></i> Forms & Policies
        </a>

        <a class="active">
            <i class="fa fa-users me-2"></i> User Management
        </a>

    </div>

    <div class="mb-3 text-center">
        <form asp-controller="Account" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()

            <button type="submit" class="btn btn-link text-danger">
                <i class="fa fa-sign-out-alt me-2"></i> Logout
            </button>
        </form>
    </div>

</div>

<!-- Main Content -->
<div class="main">

    <h4 class="mb-3">User Management</h4>
    <p class="text-muted">Home - Users</p>

    <div class="card-box">

        <div class="d-flex justify-content-between mb-3">
            <input type="text" class="form-control w-25" placeholder="Search User">
            <button class="btn btn-add">Add New User</button>
        </div>

        <table class="table align-middle">

            <thead class="text-muted">
                <tr>
                    <th>SN</th>
                    <th>NAME</th>
                    <th>EMAIL</th>
                    <th>ROLE</th>
                    <th>STATUS</th>
                    <th>ACTION</th>
                </tr>
            </thead>

            <tbody>

                <tr>
                    <td>1</td>
                    <td>Admin User</td>
                    <td>admin@tms.com</td>
                    <td><span class="role-badge role-admin">Admin</span></td>
                    <td><span class="badge bg-success">Active</span></td>
                    <td>
                        <button class="btn-action btn-edit">Edit</button>
                        <button class="btn-action btn-delete">Delete</button>
                    </td>
                </tr>

                <tr>
                    <td>2</td>
                    <td>Prakash Sharma</td>
                    <td>prakash@gmail.com</td>
                    <td><span class="role-badge role-user">User</span></td>
                    <td><span class="badge bg-success">Active</span></td>
                    <td>
                        <button class="btn-action btn-edit">Edit</button>
                        <button class="btn-action btn-delete">Delete</button>
                    </td>
                </tr>

                <tr>
                    <td>3</td>
                    <td>Bijay Shrestha</td>
                    <td>bijay@gmail.com</td>
                    <td><span class="role-badge role-user">User</span></td>
                    <td><span class="badge bg-danger">Inactive</span></td>
                    <td>
                        <button class="btn-action btn-edit">Edit</button>
                        <button class="btn-action btn-delete">Delete</button>
                    </td>
                </tr>

                <tr>
                    <td>4</td>
                    <td>Anita Sharma</td>
                    <td>anita@gmail.com</td>
                    <td><span class="role-badge role-user">User</span></td>
                    <td><span class="badge bg-success">Active</span></td>
                    <td>
                        <button class="btn-action btn-edit">Edit</button>
                        <button class="btn-action btn-delete">Delete</button>
                    </td>
                </tr>

            </tbody>

        </table>

    </div>

</div>