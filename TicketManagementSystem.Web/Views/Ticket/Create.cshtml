@using TicketManagementSystem.Common.Enum
@model TicketManagementSystem.Application.DTOs.CreateTicketDto

@{
    ViewData["Title"] = "Create Ticket";
    ViewData["Subtitle"] = "Log a new issue quickly";
}

@section Styles {
    <style>
        .create-card {
            max-width: 900px;
            margin: 0 auto;
        }
        .create-label {
            font-weight: 600;
            margin-bottom: .45rem;
        }
        .create-icon {
            min-width: 46px;
            justify-content: center;
        }
    </style>
}

@section PageActions {
    <a asp-action="Index" class="btn btn-outline-secondary tms-btn-spacious" style="border-radius:1.4rem;">
        <i class="fa-solid fa-arrow-left"></i>
        Back
    </a>
}

<div class="tms-card create-card">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="mb-4">
                <div class="h4 fw-bold mb-1">
                    <i class="fa-solid fa-circle-plus text-primary me-2"></i>Create Ticket
                </div>
                <div class="text-muted small">Provide details so the right team can pick it up quickly.</div>
            </div>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label create-label">Title</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white create-icon">
                                <i class="fa-solid fa-heading text-muted"></i>
                            </span>
                            <input asp-for="Title" class="form-control" placeholder="e.g., Email not syncing" />
                        </div>
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label create-label">Description</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white create-icon align-items-start pt-3">
                                <i class="fa-regular fa-file-lines text-muted"></i>
                            </span>
                            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Describe what happened, what you expected, and any steps to reproduce."></textarea>
                        </div>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-4">
                        <label class="form-label create-label">Issue Type</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white create-icon">
                                <i class="fa-solid fa-circle-question text-muted"></i>
                            </span>
                            <select asp-for="IssueType" class="form-select" asp-items="Html.GetEnumSelectList<IssueType>()">
                                <option value="">-- Select Issue Type --</option>
                            </select>
                        </div>
                        <span asp-validation-for="IssueType" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-4">
                        <label class="form-label create-label">Priority</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white create-icon">
                                <i class="fa-solid fa-flag text-muted"></i>
                            </span>
                            <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<TicketPriority>()">
                                <option value="">-- Select Priority --</option>
                            </select>
                        </div>
                        <span asp-validation-for="Priority" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-4">
                        <label class="form-label create-label">Branch</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white create-icon">
                                <i class="fa-solid fa-building text-muted"></i>
                            </span>
                            <select asp-for="BranchId" class="form-select" asp-items="ViewBag.Branches">
                                <option value="">-- Select Branch --</option>
                            </select>
                        </div>
                        <span asp-validation-for="BranchId" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary tms-btn-icon">
                        <i class="fa-solid fa-arrow-left"></i>
                        Back
                    </a>
                    <button type="submit" class="btn btn-success tms-btn-icon px-4">
                        <i class="fa-solid fa-check"></i>
                        Create Ticket
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}