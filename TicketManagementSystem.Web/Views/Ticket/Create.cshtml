@using TicketManagementSystem.Common.Enum
@model TicketManagementSystem.Application.DTOs.CreateTicketDto

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Create Ticket</h4>
                </div>

                <div class="card-body">

                    <form asp-action="Create" method="post">

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label">Title</label>
                            <input asp-for="Title" class="form-control" placeholder="Enter title" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4"
                                      placeholder="Describe the issue..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Issue Type</label>
                            <select asp-for="IssueType" class="form-select"
                                    asp-items="Html.GetEnumSelectList<IssueType>()">
                                <option value="">-- Select Issue Type --</option>
                            </select>
                            <span asp-validation-for="IssueType" class="text-danger"></span>
                        </div>


                        <div class="mb-3">
                            <label class="form-label">Priority</label>
                            <select asp-for="Priority" class="form-select"
                                    asp-items="Html.GetEnumSelectList<TicketPriority>()">
                                <option value="">-- Select Priority --</option>
                            </select>
                            <span asp-validation-for="Priority" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Branch</label>
                            <select asp-for="BranchId" class="form-select"
                                    asp-items="ViewBag.Branches">
                                <option value="">-- Select Branch --</option>
                            </select>
                            <span asp-validation-for="BranchId" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Back
                            </a>

                            <button type="submit" class="btn btn-success px-4">
                                Create Ticket
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}