@model TicketManagementSystem.Domain.Entities.Ticket
@using TicketManagementSystem.Common.Enum

@{
    ViewData["Title"] = "Ticket Details";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">

    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-primary text-white d-flex justify-content-between">
            <h4 class="mb-0">Ticket Details</h4>
            <a asp-action="Index" class="btn btn-light btn-sm">Back</a>
        </div>

        <div class="card-body">

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="fw-bold">Ticket No:</label>
                    <p>#TKT-@Model.Id</p>
                </div>

                <div class="col-md-6">
                    <label class="fw-bold">Status:</label><br />
                    <span class="badge @(Model.Status == TicketStatus.Open ? "bg-danger" : "bg-success")">
                        @Model.Status
                    </span>
                </div>
            </div>

            <div class="mb-3">
                <label class="fw-bold">Title:</label>
                <p>@Model.Title</p>
            </div>

            <div class="mb-3">
                <label class="fw-bold">Description:</label>
                <p>@Model.Description</p>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="fw-bold">Issue Type:</label>
                    <p>@Model.IssueType</p>
                </div>

                <div class="col-md-4">
                    <label class="fw-bold">Priority:</label>
                    <p class="@(Model.Priority == TicketPriority.High ? "text-danger" :
                                                       Model.Priority == TicketPriority.Medium ? "text-warning" : "text-success")">
                        @Model.Priority
                    </p>
                </div>

                <div class="col-md-4">
                    <label class="fw-bold">Branch:</label>
                    <p>@(Model.BranchName?.BranchCode ?? "-")</p>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <label class="fw-bold">Created At:</label>
                    <p>@Model.CreatedAt.ToString("yyyy-MM-dd hh:mm tt")</p>
                </div>

                <div class="col-md-6">
                    <label class="fw-bold">Resolved At:</label>
                    <p>@(Model.ResolvedAt.HasValue? Model.ResolvedAt.Value.ToString("yyyy-MM-dd hh:mm tt") : "-")</p>
                </div>
            </div>

        </div>
    </div>

</div>