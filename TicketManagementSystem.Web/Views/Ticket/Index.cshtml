@model List<TicketManagementSystem.Domain.Entities.Ticket>
@using TicketManagementSystem.Common.Enum
@using TicketManagementSystem.Domain.Entities

@{
    ViewData["Title"] = "Tickets";
    ViewData["Subtitle"] = "Track, assign, and resolve issues smoothly";

    var pageNumber = ViewBag.PageNumber as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 10;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
    var totalPages = ViewBag.TotalPages as int? ?? 0;
    var filterStatus = ViewBag.FilterStatus as TicketStatus?;
    var filterBranchId = ViewBag.FilterBranchId as int?;
    var filterMyTickets = ViewBag.FilterMyTickets as bool? ?? false;
    var filterSearch = ViewBag.FilterSearch as string ?? string.Empty;
    var allBranches = ViewBag.AllBranches as List<Branch> ?? new List<Branch>();

    int sn = (pageNumber - 1) * pageSize + 1;
    var users = ViewBag.Users as List<TicketManagementSystem.Infrastructure.Identity.ApplicationUser>;
}

@section PageActions {
    <a asp-controller="Ticket" asp-action="Create" class="btn btn-primary tms-btn-spacious" style="border-radius:1.4rem;">
        <i class="fa-solid fa-plus"></i>
        Create Ticket
    </a>
}

<div class="tms-card">
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
        <div>
            <div class="h4 mb-1 fw-bold" style="letter-spacing:.03em;">
                <i class="fa-solid fa-list-check text-primary me-1"></i>All Tickets
            </div>
            <div class="text-muted small">Showing <strong>@(Model?.Count ?? 0)</strong> of <strong>@totalCount</strong> ticket(s)</div>
        </div>
    </div>

    <form method="get" asp-action="Index" class="row g-2 align-items-end mb-3 mb-md-4">
        <div class="col-6 col-md-2">
            <label class="form-label small text-muted mb-0">Status</label>
            <select name="status" class="form-select form-select-sm">
                <option value="">All</option>
                @foreach (var st in Enum.GetValues<TicketStatus>())
                {
                    if (filterStatus == st)
                    {
                        <option value="@((int)st)" selected="selected">@st</option>
                    }
                    else
                    {
                        <option value="@((int)st)">@st</option>
                    }
                }
            </select>
        </div>
        <div class="col-6 col-md-2">
            <label class="form-label small text-muted mb-0">Branch</label>
            <select name="branchId" class="form-select form-select-sm">
                <option value="">All</option>
                @foreach (var b in allBranches)
                {
                    if (filterBranchId == b.BranchId)
                    {
                        <option value="@b.BranchId" selected="selected">@b.BranchCode</option>
                    }
                    else
                    {
                        <option value="@b.BranchId">@b.BranchCode</option>
                    }
                }
            </select>
        </div>
        <div class="col-6 col-md-2 d-flex align-items-center pt-3 pt-md-4">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="myTickets" value="true" id="myTickets" @(filterMyTickets ? "checked" : null) />
                <label class="form-check-label small" for="myTickets">My tickets</label>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <label class="form-label small text-muted mb-0">Search</label>
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-white border-end-0">
                    <i class="fa-solid fa-magnifying-glass text-muted"></i>
                </span>
                <input type="text" name="search" value="@filterSearch" class="form-control border-start-0" placeholder="Title or description" />
            </div>
        </div>
        <div class="col-6 col-md-2">
            <input type="hidden" name="page" value="1" />
            <button type="submit" class="btn btn-primary btn-sm w-100 tms-btn-spacious py-2">
                <i class="fa-solid fa-filter"></i> Apply
            </button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table align-middle tms-table mb-0">
            <thead>
                <tr>
                    <th style="width:56px;text-align:center"><i class="fa-solid fa-hashtag" title="Serial Number"></i></th>
                    <th><i class="fa-solid fa-barcode me-1"></i>ID</th>
                    <th><i class="fa-solid fa-circle-question me-1"></i>Issue</th>
                    <th><i class="fa-solid fa-arrow-up-wide-short me-1"></i>Priority</th>
                    <th><i class="fa-solid fa-bolt me-1"></i>Status</th>
                    <th><i class="fa-solid fa-user-tag me-1"></i>Picked By</th>
                    <th><i class="fa-solid fa-user-pen me-1"></i>Created By</th>
                    <th style="width:220px;"><i class="fa-solid fa-gear me-1"></i>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var createdBy = users?.FirstOrDefault(u => u.Id == item.CreatedById)?.UserName;
                        var assignedTo = users?.FirstOrDefault(u => u.Id == item.AssignedToId)?.UserName;
                        var statusBadgeClass = item.Status == TicketStatus.Open ? "badge-open" : "badge-closed";
                        var priorityBadgeClass =
                            item.Priority == TicketPriority.High ? "badge-priority-high" :
                            item.Priority == TicketPriority.Medium ? "badge-priority-medium" :
                            "badge-priority-low";

                        <tr>
                            <td class="text-muted fw-bold text-center">@sn</td>
                            <td>
                                <span class="fw-bold text-primary" style="font-size:1.1em; letter-spacing:.035em;">
                                    #TKT-@item.Id
                                </span>
                            </td>
                            <td class="text-muted">@item.IssueType</td>
                            <td>
                                <span class="badge badge-soft @priorityBadgeClass">
                                    @if (item.Priority == TicketPriority.High)
                                    {<i class="fa-solid fa-arrow-up"></i> }
                                    else if (item.Priority == TicketPriority.Medium)
                                    {<i class="fa-solid fa-arrow-right"></i> }
                                    else
                                    {<i class="fa-solid fa-arrow-down"></i>}
                                    @item.Priority
                                </span>
                            </td>
                            <td>
                                <span class="badge badge-soft @statusBadgeClass">
                                    @if (item.Status == TicketStatus.Open)
                                    {<i class="fa-solid fa-circle-play"></i>}
                                    else
                                    {<i class="fa-solid fa-circle-check"></i>}
                                    @item.Status
                                </span>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(assignedTo))
                                {
                                    <span class="fw-semibold text-success"><i class="fa fa-user"></i> @assignedTo</span>
                                }
                                else
                                {
                                    <span class="text-muted"><i class="fa fa-user-slash"></i> -</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(createdBy))
                                {
                                    <span class="fw-semibold text-primary"><i class="fa fa-user"></i> @createdBy</span>
                                }
                                else
                                {
                                    <span class="text-muted"><i class="fa fa-user"></i> -</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary tms-btn-icon" title="View ticket details">
                                        <i class="fa-regular fa-eye"></i>
                                        Details
                                    </a>
                                    @if (item.AssignedToId == null)
                                    {
                                        <form asp-action="Assign" method="post" class="m-0" style="display:inline;">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-warning tms-btn-icon" title="Assign ticket">
                                                <i class="fa-solid fa-hand-pointer"></i>
                                                Assign
                                            </button>
                                        </form>
                                    }
                                    @if (item.Status == TicketStatus.Open)
                                    {
                                        <form asp-action="Resolve" method="post" class="m-0" style="display:inline;">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-success tms-btn-icon" title="Resolve ticket">
                                                <i class="fa-regular fa-circle-check"></i>
                                                Resolve
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                        sn++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8">
                            <div class="tms-empty-state">
                                <i class="fa-regular fa-folder-open"></i>
                                <div class="fw-semibold mt-2">No tickets found</div>
                                <div class="small mt-1">Create a ticket to get started.</div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <nav class="d-flex justify-content-center mt-4" aria-label="Ticket pages">
            <ul class="pagination pagination-sm mb-0 flex-wrap">
                @for (var p = 1; p <= totalPages; p++)
                {
                    <li class="page-item @(p == pageNumber ? "active" : null)">
                        <a class="page-link rounded-pill mx-1"
                           asp-action="Index"
                           asp-route-page="@p"
                           asp-route-status="@filterStatus"
                           asp-route-branchId="@filterBranchId"
                           asp-route-search="@filterSearch"
                           asp-route-myTickets="@(filterMyTickets ? true : (bool?)null)">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
