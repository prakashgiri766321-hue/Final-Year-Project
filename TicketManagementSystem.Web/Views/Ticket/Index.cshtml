                </tr>

                <tr>
                    <td>4</td>
                    <td>0260310-GNB-003</td>
                    <td>Network</td>
                    <td class="priority-high">High</td>
                    <td><span class="status-closed">Closed</span></td>
                    <td>karan</td>
                    <td>Gongabu H (GNB)</td>
                    <td>SANGITA ADHIKARI</td>
                    <td><button class="details-btn">Details</button></td>
                </tr>

                <tr>
                    <td>5</td>
                    <td>0260310-KTM-002</td>
                    <td>Software</td>
                    <td class="priority-high">High</td>
                    <td><span class="status-closed">Closed</span></td>
                    <td>prakash</td>
                    <td>HeadOffice (KTM)</td>
                    <td>Bijay Shrestha</td>
                    <td><button class="details-btn">Details</button></td>
                </tr>

                <tr>
                    <td>6</td>
                    <td>0260310-LPT-001</td>
                    <td>Software</td>
