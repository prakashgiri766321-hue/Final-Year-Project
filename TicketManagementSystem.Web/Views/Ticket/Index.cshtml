@{
    ViewData["Title"] = "Ticket List";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

<style>

    body {
        background: #f6f7fb;
        font-family: "Segoe UI",sans-serif;
    }

    .sidebar {
        width: 250px;
        height: 100vh;
        background: #fff;
        position: fixed;
        left: 0;
        top: 0;
        border-right: 1px solid #eee;
    }

        .sidebar .logo {
            padding: 20px;
            font-weight: bold;
            color: #0d6efd;
        }

        .sidebar a {
            display: block;
            padding: 14px 20px;
            color: #555;
            text-decoration: none;
        }

            .sidebar a:hover,
            .sidebar a.active {
                background: #f0f4ff;
                color: #0d6efd;
                font-weight: 500;
            }

    .main {
        margin-left: 260px;
        padding: 30px;
    }



    .ticket-table {
        background: white;
        border-radius: 10px;
        padding: 20px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.05);
    }

    .search-box {
        width: 250px;
    }


    .status-open {
        background: #ffe5e8;
        color: #ff4d5a;
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 12px;
    }

    .status-closed {
        background: #d9f7e9;
        color: #1fb46a;
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 12px;
    }

    .priority-high {
        color: #ff4d5a;
        font-weight: 500;
    }

    .priority-medium {
        color: #f5a623;
        font-weight: 500;
    }

    .details-btn {
        background: linear-gradient(90deg,#7c4dff,#5b3cff);
        color: white;
        border: none;
        padding: 6px 18px;
        border-radius: 8px;
    }

        .details-btn:hover {
            opacity: .9;
        }

</style>

<div class="sidebar d-flex flex-column justify-content-between">

    <div>

        <div class="logo">
            🎫 TMS<br>
            <small class="text-muted">Ticket Management System</small>
        </div>

        <a asp-controller="Home" asp-action="Index">
            <i class="fa fa-chart-pie me-2"></i> Dashboard
        </a>

        <a class="active">
            <i class="fa fa-ticket me-2"></i> Tickets
        </a>

        <a asp-controller="FormAndPolicies" asp-action="Index">
            <i class="fa fa-file-alt me-2"></i> Forms & Policies
        </a>
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="UserManagement" asp-action="Index">
                <i class="fa fa-users me-2"></i> User Management
            </a>
        }

    </div>


    <div class="mb-3 text-center">

        <form asp-controller="Account" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()

            <button type="submit" class="btn btn-link text-danger">
                <i class="fa fa-sign-out-alt me-2"></i> Logout
            </button>

        </form>

    </div>

</div>

<div class="main">

    <div class="d-flex justify-content-between align-items-center mb-3">

        <input type="text" class="form-control search-box" placeholder="Search Ticket">

        <div>
            <button class="btn btn-light me-2">Filter</button>
            <button class="btn btn-light">Export to Excel</button>
        </div>

    </div>


    <div class="ticket-table">

        <table class="table align-middle">

            <thead class="text-muted">

                <tr>
                    <th>SN</th>
                    <th>TICKET NO.</th>
                    <th>ISSUE TYPE</th>
                    <th>PRIORITY</th>
                    <th>STATUS</th>
                    <th>PICKED BY</th>
                    <th>CREATED BY</th>
                    <th>REPORTED BY</th>
                    <th>ACTIONS</th>
                </tr>

            </thead>


            <tbody>

                <tr>
                    <td>1</td>
                    <td>0260310-BRJ-006</td>
                    <td>Software</td>
                    <td class="priority-high">High</td>
                    <td><span class="status-open">Open</span></td>
                    <td>-</td>
                    <td>Birgunj H (BRJ)</td>
                    <td>SUDHA BANIYA</td>
