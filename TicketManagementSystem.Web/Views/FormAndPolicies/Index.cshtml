@{
    ViewData["Title"] = "Forms & Policies";
    ViewData["Subtitle"] = "Quick access to documents and policies";
}
@section PageActions {
    <button class="btn btn-primary tms-btn-spacious" style="border-radius:1.4rem;" disabled>
        <i class="fa-solid fa-plus"></i>
        Add New
    </button>
}

<div class="tms-card">
    <div class="table-responsive">
        <table class="table align-middle tms-table mb-0">
            <thead>
                <tr>
                    <th style="width:80px;">SN</th>
                    <th>NAME</th>
                    <th style="width:180px;">LAST UPDATED</th>
                    <th style="width:260px;">ACTION</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var rows = new[]
                    {
                        new { Name = "Document Control Policy", Date = "15/11/2024" },
                        new { Name = "IT Policy", Date = "15/11/2024" },
                        new { Name = "Internet Usage Policy", Date = "15/11/2024" },
                        new { Name = "IT Security Policy", Date = "15/11/2024" },
                        new { Name = "Email Usage Policy", Date = "15/11/2024" },
                        new { Name = "Network Security Policy", Date = "15/11/2024" },
                    };
                    var sn = 1;
                }

                @foreach (var r in rows)
                {
                    <tr>
                        <td class="text-muted fw-bold">@sn</td>
                        <td>
                            <span class="fw-semibold">
                                <i class="fa-solid fa-file-lines text-primary me-2"></i>@r.Name
                            </span>
                        </td>
                        <td class="text-muted">@r.Date</td>
                        <td>
                            <div class="d-flex flex-wrap gap-2">
                                <button class="btn btn-sm btn-primary tms-btn-icon" disabled>
                                    <i class="fa-regular fa-eye"></i> Preview
                                </button>
                                <button class="btn btn-sm btn-warning tms-btn-icon" disabled>
                                    <i class="fa-regular fa-pen-to-square"></i> Edit
                                </button>
                                <button class="btn btn-sm btn-danger tms-btn-icon" disabled>
                                    <i class="fa-regular fa-trash-can"></i> Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                    sn++;
                }
            </tbody>
        </table>
    </div>
</div>